# --- Database (Supabase Postgres) ---
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# --- Auth ---
JWT_SECRET=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me

# --- Groq LLM ---
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.5

# --- Embeddings (free, local, no API key needed) ---
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Vector DB (ChromaDB) ---
# Local persistent path on Render disk, OR a hosted Chroma server URL
CHROMA_MODE=persistent          # persistent | http
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_HTTP_HOST=
CHROMA_HTTP_PORT=8000

# --- Gmail API (Google Cloud OAuth 2.0 Client) ---
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx
GOOGLE_REDIRECT_URI=https://your-backend.onrender.com/api/gmail/oauth/callback
GMAIL_POLL_INTERVAL_SECONDS=60

# --- Optional Escalation Webhook ---
SLACK_WEBHOOK_URL=

# --- CORS ---
FRONTEND_ORIGIN=https://your-app.vercel.app
